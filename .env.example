OPEN_OTC_DATABASE_URL="sqlite+pysqlite:///./data/open_otc.sqlite3"
OPEN_OTC_ARTIFACT_DIR="./artifacts"

# Channel/model catalog: see config/agent_channels.yaml
# Each channel's api_key_env names the env var that holds its API key.
ZENMUX_API_KEY=""
ZENMUX_MANAGEMENT_KEY=""
DEEPSEEK_API_KEY=""
# Optional override for the YAML path:
# AGENT_CHANNELS_FILE="./config/agent_channels.yaml"

AGENT_CHECKPOINT_DB_PATH="./agent_checkpoints.sqlite"
OPEN_OTC_ASYNC_TASK_WORKERS="1"
OPEN_OTC_RISK_PARALLEL_WORKERS="8"
OPEN_OTC_AGENT_RECURSION_LIMIT="100"
OPEN_OTC_AGENT_STREAM_VERSION="v3"
OPEN_OTC_AGENT_CODE_INTERPRETER="false"

LANGSMITH_TRACING="false"
LANGCHAIN_TRACING_V2="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="open-otc-trading"

# Session tracing: local (self-hosted audit store, default) | langsmith | both | off
OPEN_OTC_TRACING="local"
OPEN_OTC_TRACE_DB_PATH="./data/agent_traces.sqlite3"

VITE_API_TARGET="http://localhost:8000"

#lark
GATEWAY_ENABLED_CONNECTORS=feishu      # "" = fully inert; this is the on-switch
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
GATEWAY_DEFAULT_DESK_USER=desk_trader  # actor threaded into audit
GATEWAY_WEB_BASE_URL=http://localhost:3000   # optional: enables card deep-links back to web desk
